load("@rules_cc//cc:cc_library.bzl", "cc_library")
load("@rules_rust//rust:defs.bzl", "rust_binary", "rust_library")
load("@score_baselibs//score/language/safecpp:toolchain_features.bzl", "COMPILER_WARNING_FEATURES")

cc_library(
    name = "car_window_types_cpp",
    srcs = [
        "src/car_window_types.cpp",
    ],
    hdrs = [
        "src/car_window_types.h",
    ],
    copts = ["-fPIC"],
    features = COMPILER_WARNING_FEATURES,
    linkopts = ["-latomic"],
    visibility = ["//visibility:public"],
    deps = [
        "@score_baselibs//score/language/futurecpp",
        "@score_communication//score/mw/com",
    ],
)

filegroup(
    name = "public_headers",
    srcs = ["src/car_window_types.h"],
    visibility = ["//visibility:public"],
)

cc_library(
    name = "car_window_types_ipc_gen_cpp",
    srcs = ["src/car_window_types_ipc_gen.cpp"],
    copts = ["-mno-outline-atomics"],
    features = COMPILER_WARNING_FEATURES,
    implementation_deps = [
        ":car_window_types_cpp",
        "@score_communication//score/mw/com/impl/rust:bridge_macros",
    ],
    # Link options
    linkopts = [
        "-latomic",  # Required for atomic operations
    ],
    visibility = ["//visibility:public"],  # Optional: make it visible to other targets
)

rust_library(
    name = "car_window_types",
    srcs = ["src/car_window_types.rs"],
    visibility = ["//visibility:public"],
    deps = [
        ":car_window_types_ipc_gen_cpp",
        "@score_communication//score/mw/com/impl/rust:mw_com",
    ],
)

cc_binary(
    name = "car_window_cpp",
    srcs = [
        "src/car_window.cpp",
    ],
    copts = [
        "-mno-outline-atomics",
    ],
    data = [
        "config/logging.json",
        "config/mw_com_config.json",
    ],
    features = COMPILER_WARNING_FEATURES,
    includes = ["src"],
    linkopts = [
        "-latomic",
    ],
    visibility = ["//visibility:public"],
    deps = [
        ":car_window_types_cpp",
        "@score_baselibs//score/language/futurecpp",
        "@score_communication//score/mw/com",
    ],
)

