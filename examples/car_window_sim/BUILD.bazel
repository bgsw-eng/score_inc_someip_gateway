cc_binary(
    name = "car_window_controller_cpp",
    srcs = [
        "src/car_window_controller.cpp",
    ],
    copts = [
        "-mno-outline-atomics",
    ],
    data = [
        "config/logging.json",
        "config/mw_com_config.json",
    ],
    features = COMPILER_WARNING_FEATURES,
    includes = ["src"],
    linkopts = [
        "-latomic",
    ],
    visibility = ["//visibility:public"],
    deps = [
        ":car_window_types_cpp",
        # If you need the bridge exports at link-time, uncomment this line:
        # ":car_window_types_ipc_gen_cpp",
        "@score_communication//score/mw/com",
        "@score_baselibs//score/language/futurecpp",
    ],
)
